# Marcha Pay (PIX) - obrigatório para gerar PIX
# Obtenha em https://marchapay.com.br ou painel Marcha Pay
MARCHABB_PUBLIC_KEY=sua_public_key_aqui
MARCHABB_SECRET_KEY=sua_secret_key_aqui

# URL do site (para webhook e returnUrl do PIX). Em produção use https://seusite.com.br
SITE_URL=http://localhost:3000

# Porta do servidor
PORT=3000

# Utmify - trackeamento de vendas (opcional). Deixe vazio se não usar.
# UTMIFY_API_TOKEN=seu_token_aqui
